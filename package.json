{
  "name": "minemonlauncher",
  "version": "1.0.0",
  "productName": "Minemon Launcher",
  "description": "Launcher para el servidor Minemon - Minecraft con Cobblemon",
  "author": "Minemon",
  "license": "UNLICENSED",
  "homepage": "https://github.com/minemon/launcher",
  "private": true,
  "main": "index.js",

  "scripts": {
    "start": "electron .",
    "dist": "electron-builder build",
    "dist:win": "npm run dist -- -w",
    "dist:mac": "npm run dist -- -m",
    "dist:linux": "npm run dist -- -l",
    "lint": "eslint ."
  },

  "engines": {
    "node": "22.x.x"
  },

  "dependencies": {
    "@electron/remote": "^2.1.3",
    "adm-zip": "^0.5.16",
    "discord-rpc-patch": "^4.0.1",
    "ejs": "^3.1.10",
    "ejs-electron": "^3.0.0",
    "electron-updater": "^6.7.3",
    "fs-extra": "^11.3.3",
    "github-syntax-dark": "^0.5.0",
    "got": "^11.8.5",
    "helios-core": "~2.3.0",
    "helios-distribution-types": "^1.3.0",
    "jquery": "^3.7.1",
    "lodash.merge": "^4.6.2",
    "semver": "^7.7.3",
    "toml": "^3.0.0"
  },

  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.6.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0",
    "eslint": "^9.39.2"
  },

  "build": {
    "appId": "es.minemon.launcher",
    "productName": "Minemon Launcher",
    "artifactName": "Minemon-Launcher-${version}-Setup.${ext}",
    "asar": true,

    "directories": {
      "buildResources": "build",
      "output": "dist"
    },

    "files": [
      "**/*",
      "!**/*.map",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}"
    ],

"win": {
  "signAndEditExecutable": false,
  "verifyUpdateCodeSignature": false,
  "forceCodeSigning": false,
  "target": [
    {
      "target": "nsis",
      "arch": ["x64"]
    }
  ],
  "icon": "build/icon.ico"
}
,

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Minemon Launcher"
    },

    "publish": [
      {
        "provider": "github",
        "owner": "TU_USUARIO_GITHUB",
        "repo": "minemon-launcher"
      }
    ]
  },

  "repository": {
    "type": "git",
    "url": "https://github.com/minemon/launcher.git"
  }
}
